# Smart Ride Connect - Environment Variables

# Node Environment
NODE_ENV=development

# JWT Secret - Generate a secure random string for production
# Run: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-key-change-in-production

# Database (Supabase PostgreSQL)
# Set up at: https://supabase.com/dashboard → Your Project → Settings → Database
# Connection string format: postgres://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Or use individual parameters:
DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
POSTGRES_HOST=db.[YOUR-PROJECT].supabase.co
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DB=postgres

# Supabase Configuration (optional - for additional Supabase features)
SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# API Configuration
API_URL=http://localhost:3000
API_RATE_LIMIT=100

# M-Pesa Configuration (if using mobile payments)
Mpesa_CONSUMER_KEY=your-mpesa-consumer-key
Mpesa_CONSUMER_SECRET=your-mpesa-consumer-secret
Mpesa_SHORTCODE=your-mpesa-shortcode
Mpesa_PASSKEY=your-mpesa-passkey
Mpesa_ENV=development

# External APIs
MAPS_API_KEY=your-google-maps-api-key
SMS_API_KEY=your-sms-api-key

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
COOKIE_SECRET=your-cookie-secret-change-in-production
