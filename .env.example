# Smart Ride Connect - Environment Variables

# Node Environment
NODE_ENV=development

# JWT Secret - Generate a secure random string for production
# Run: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-key-change-in-production

# Database (Vercel Postgres)
# Set up at: https://vercel.com/storage → Create Database → Postgres
# Vercel automatically sets POSTGRES_URL as an environment variable
POSTGRES_URL=postgres://user:password@host:5432/database

# Alternative: Individual PostgreSQL parameters (if not using POSTGRES_URL)
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DB=postgres

# API Configuration
API_URL=http://localhost:3000
API_RATE_LIMIT=100

# M-Pesa Configuration (if using mobile payments)
Mpesa_CONSUMER_KEY=your-mpesa-consumer-key
Mpesa_CONSUMER_SECRET=your-mpesa-consumer-secret
Mpesa_SHORTCODE=your-mpesa-shortcode
Mpesa_PASSKEY=your-mpesa-passkey
Mpesa_ENV=development

# External APIs
MAPS_API_KEY=your-google-maps-api-key
SMS_API_KEY=your-sms-api-key

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production
COOKIE_SECRET=your-cookie-secret-change-in-production
